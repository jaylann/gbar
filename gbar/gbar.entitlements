<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox: required for Mac App Store & good hygiene for a menu-bar app. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!-- Outbound HTTPS to the GitHub API (and Enterprise hosts). -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- NOTE: no keychain-access-groups here — this is the teamless/ad-hoc default (fresh
	     clone / CI), where that entitlement would require a provisioning profile and fail the
	     build. A team-signed build selects gbar-signed.entitlements via GBAR_ENTITLEMENTS,
	     which adds the group; teamless builds fall back to the file-based keychain. -->
</dict>
</plist>
